# ── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bankuser:bankpass@bank-assistant-db:5432/bankdb
POSTGRES_USER=bankuser
POSTGRES_PASSWORD=bankpass
POSTGRES_DB=bankdb

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
SECRET_KEY=change-me-use-openssl-rand-hex-32
DEBUG=false

# ── IA (Groq) ─────────────────────────────────────────────────────────────────
# Obtenir sur https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_SMART=llama-3.3-70b-versatile

# ── Open Banking (Bridge API) ─────────────────────────────────────────────────
# Obtenir sur https://bridgeapi.io
BRIDGE_CLIENT_ID=your-bridge-client-id
BRIDGE_CLIENT_SECRET=your-bridge-client-secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# ── Premier utilisateur (créé automatiquement au démarrage) ───────────────────
# Laisser vide pour désactiver la création automatique
FIRST_USER_EMAIL=admin@example.com
FIRST_USER_PASSWORD=changeme
FIRST_USER_NAME=Admin

# ── Production ────────────────────────────────────────────────────────────────
REGISTRY=ghcr.io/your-username
IMAGE_TAG=latest
CORS_ORIGINS=["http://localhost:3000"]
